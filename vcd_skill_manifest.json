{
  "name": "vcd_analyzer",
  "version": "2.0.0",
  "description": "VCD waveform analysis toolkit exposed as AI Agent Skills. Each Skill emits a standardized JSON envelope ({status, skill, execution_time_ms, input, result, metadata, suggestions}) so any LLM-based Agent (Claude Code, GPT-4 function calling, LangChain, MCP) can call it the same way.",
  "envelope": {
    "success": {
      "status": "success",
      "skill": "<name>",
      "execution_time_ms": "int",
      "input": "echo of inputs",
      "result": "skill-specific result payload",
      "metadata": {
        "vcd_file_size": "int (bytes)",
        "analyzer_version": "string",
        "signals_matched": "int",
        "time_range_analyzed": "[start, end]"
      },
      "suggestions": "string[] — next-step guidance for the Agent"
    },
    "error": {
      "status": "error",
      "skill": "<name>",
      "execution_time_ms": "int",
      "input": "echo of inputs",
      "error": {
        "code": "one of FILE_NOT_FOUND | PARSE_ERROR | INVALID_PROTOCOL | SIGNAL_NOT_FOUND | INVALID_TIME_RANGE | INVALID_ARGUMENT | INSUFFICIENT_DATA | RESOURCE_LIMIT | INTERNAL_ERROR",
        "message": "human-readable summary",
        "details": "diagnostic dict (e.g. supported alternatives, available signals)"
      },
      "suggestions": []
    }
  },
  "error_codes": [
    {"code": "FILE_NOT_FOUND", "description": "VCD file does not exist or cannot be opened"},
    {"code": "PARSE_ERROR", "description": "VCD file format is invalid or corrupt"},
    {"code": "INVALID_PROTOCOL", "description": "Requested protocol is not supported"},
    {"code": "SIGNAL_NOT_FOUND", "description": "Signal pattern matched zero or multiple signals when one was required"},
    {"code": "INVALID_TIME_RANGE", "description": "Time argument failed to parse or end < begin"},
    {"code": "INVALID_ARGUMENT", "description": "A CLI argument is malformed (filter pattern, condition, etc.)"},
    {"code": "INSUFFICIENT_DATA", "description": "The VCD does not have enough events to complete the analysis"},
    {"code": "RESOURCE_LIMIT", "description": "Input exceeds configured resource limits"},
    {"code": "INTERNAL_ERROR", "description": "Unhandled exception inside the Skill — please report"}
  ],
  "capabilities": [
    {
      "skill": "info",
      "command": "info",
      "description": "Inspect a VCD file's metadata: timescale, signal count, scope list, time span, and tool provenance. Lowest-cost first call to ground any downstream analysis.",
      "category": "basic_query",
      "input_schema": {
        "type": "object",
        "properties": {
          "file": {"type": "string", "description": "Path to VCD file"}
        },
        "required": ["file"]
      },
      "result_schema": {
        "file": "absolute path",
        "size_bytes": "file size",
        "timescale": "human-readable timescale (e.g. '1ns')",
        "signal_count": "int",
        "time_min": "human-readable earliest event time",
        "time_max": "human-readable latest event time",
        "duration": "max - min",
        "scopes": "list of declared scope paths"
      },
      "example_cli": "python vcd_analyzer.py info sim.vcd --json"
    },
    {
      "skill": "list",
      "command": "list",
      "description": "List signals declared in a VCD file, optionally filtered by a glob/substring pattern. Returns paths, widths, and types.",
      "category": "basic_query",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":   {"type": "string", "description": "Path to VCD file"},
          "filter": {"type": "string", "description": "Comma-separated substring/glob patterns (case-insensitive)"}
        },
        "required": ["file"]
      },
      "result_schema": {
        "total": "int — total matched",
        "shown": "int — entries returned (after --limit)",
        "truncated": "bool",
        "signals": "array of {path, width, type}"
      },
      "example_cli": "python vcd_analyzer.py list sim.vcd --filter axi --json"
    },
    {
      "skill": "dump",
      "command": "dump",
      "description": "Stream value-change events in time order. Filter by signal pattern and time range.",
      "category": "basic_query",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":   {"type": "string"},
          "filter": {"type": "string", "description": "Comma-separated substring/glob patterns"},
          "begin":  {"type": "string", "description": "Start time (e.g. 100ns, 17.5us)"},
          "end":    {"type": "string", "description": "End time"}
        },
        "required": ["file"]
      },
      "result_schema": {
        "shown": "int — events returned",
        "truncated": "bool",
        "events": "array of {time, time_ticks, time_h, path, value}"
      },
      "example_cli": "python vcd_analyzer.py dump sim.vcd --begin 100ns --end 200ns --filter clk --json"
    },
    {
      "skill": "summary",
      "command": "summary",
      "description": "Aggregate per-signal statistics over a time window: classify signals as active/static/undefined, with rise/fall counts and first/last change.",
      "category": "basic_query",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":   {"type": "string"},
          "filter": {"type": "string"},
          "begin":  {"type": "string"},
          "end":    {"type": "string"}
        },
        "required": ["file"]
      },
      "result_schema": {
        "window": "{begin, end}",
        "selected": "int",
        "defined": "int",
        "undefined": "int",
        "active": "int",
        "static": "int",
        "rows": "array of per-signal stat objects"
      },
      "example_cli": "python vcd_analyzer.py summary sim.vcd --begin 0 --end 1ms --filter axi --json"
    },
    {
      "skill": "snapshot",
      "command": "snapshot",
      "description": "Return known signal values at a specific time point. Useful for grounding causality questions ('what was the state at the failure time?').",
      "category": "basic_query",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":   {"type": "string"},
          "at":     {"type": "string", "description": "Time point (e.g. 17.55us)"},
          "filter": {"type": "string"}
        },
        "required": ["file", "at"]
      },
      "result_schema": {
        "at": "human-readable time",
        "selected": "int",
        "known": "int",
        "undefined": "int",
        "signals": "array of {path, value}"
      },
      "example_cli": "python vcd_analyzer.py snapshot sim.vcd --at 17.55us --json"
    },
    {
      "skill": "compare",
      "command": "compare",
      "description": "Diff known signal values between two time points; ideal for before/after triage of a state change.",
      "category": "basic_query",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":   {"type": "string"},
          "at":     {"type": "string", "description": "Two times separated by comma, e.g. '17.5us,17.7us'"},
          "filter": {"type": "string"}
        },
        "required": ["file", "at"]
      },
      "result_schema": {
        "t1": "first time",
        "t2": "second time",
        "total": "int — changed signals",
        "diffs": "array of {path, at_t1, at_t2}"
      },
      "example_cli": "python vcd_analyzer.py compare sim.vcd --at 17.5us,17.7us --json"
    },
    {
      "skill": "search",
      "command": "search",
      "description": "Conditional search over a time window. Returns intervals where the conjunction of equality predicates (e.g. 'valid=1,ready=1') holds, or events when a watched signal changes inside that window.",
      "category": "basic_query",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":      {"type": "string"},
          "condition": {"type": "string", "description": "Comma-separated AND conditions; e.g. 'valid=1,ready=1'. != also supported."},
          "show":      {"type": "string", "description": "Comma-separated signals to observe while the condition holds; segments split when shown values change"},
          "changed":   {"type": "string", "description": "Emit events only when this signal really changes (must resolve to exactly one)"},
          "begin":     {"type": "string"},
          "end":       {"type": "string"}
        },
        "required": ["file", "condition"]
      },
      "result_schema": {
        "mode": "'interval' | 'segment' | 'event'",
        "condition": "echo of the input condition",
        "intervals": "(interval mode) array of {begin_ticks, end_ticks}",
        "segments":  "(segment mode) array of intervals enriched with show values",
        "events":    "(event mode) array of {time_ticks, time_h, values}"
      },
      "example_cli": "python vcd_analyzer.py search sim.vcd --condition 'valid=1,ready=1' --show data --json"
    },
    {
      "skill": "protocol_decode",
      "command": "protocol-decode",
      "description": "Decode bus protocol transactions (AXI4 / APB / UART / SPI). Returns transactions, protocol violations, and performance statistics.",
      "category": "protocol_analysis",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":     {"type": "string", "description": "Path to VCD file"},
          "protocol": {"type": "string", "enum": ["axi4", "apb", "uart", "spi"]},
          "signals":  {"type": "string", "description": "Comma-separated signal patterns (substring or glob)"},
          "begin":    {"type": "string", "description": "Start time (e.g. 100ns, 17.5us)"},
          "end":      {"type": "string", "description": "End time (same format as begin)"}
        },
        "required": ["file", "protocol"]
      },
      "result_schema": {
        "transactions": "array of decoded transactions (fields vary by protocol)",
        "violations": "array of protocol violations",
        "statistics": "summary stats (counts, latency, bandwidth, baud, etc.)"
      },
      "example_cli": "python vcd_analyzer.py protocol-decode sim.vcd --protocol axi4 --signals \"m_axi_*\" --json"
    },
    {
      "skill": "fsm_trace",
      "command": "fsm-trace",
      "description": "Extract state machine transitions from a state signal. Detects stuck states and provides per-state duration statistics.",
      "category": "behavioral_analysis",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":             {"type": "string"},
          "state":            {"type": "string", "description": "Signal pattern that must resolve to exactly one signal"},
          "stuck_threshold":  {"type": "string", "description": "Duration above which a state is reported stuck (default 100us)"},
          "begin":            {"type": "string"},
          "end":              {"type": "string"}
        },
        "required": ["file", "state"]
      },
      "result_schema": {
        "transitions": "array of {from, to, time, duration_in_from}",
        "anomalies": "array of detected anomalies (stuck_state, ...)",
        "statistics": "per-state occurrence counts and durations"
      },
      "example_cli": "python vcd_analyzer.py fsm-trace sim.vcd --state fsm_state --json"
    },
    {
      "skill": "causality",
      "command": "causality",
      "description": "Find potential causes for a signal change at a specific time. Ranks candidates by temporal proximity (40%) and historical correlation (60%); automatically filters clock-like signals.",
      "category": "root_cause_analysis",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":   {"type": "string"},
          "effect": {"type": "string", "description": "Effect signal pattern (must resolve to exactly one signal)"},
          "at":     {"type": "string", "description": "Time when the effect was observed"},
          "window": {"type": "string", "description": "Search window before --at (default 100ns)"}
        },
        "required": ["file", "effect", "at"]
      },
      "result_schema": {
        "effect": "info about the effect signal and value",
        "potential_causes": "array of candidate causes with correlation/confidence",
        "causal_chain": "candidates plus effect arranged chronologically"
      },
      "example_cli": "python vcd_analyzer.py causality sim.vcd --effect error_flag --at 17.5us --json"
    },
    {
      "skill": "anomaly_detect",
      "command": "anomaly-detect",
      "description": "Detect common waveform anomalies: stuck signals, glitches, metastability, bus contention. Severity-classified output suitable for triage.",
      "category": "quality_check",
      "input_schema": {
        "type": "object",
        "properties": {
          "file":             {"type": "string"},
          "filter":           {"type": "string", "description": "Restrict analysis to matching signals"},
          "begin":            {"type": "string"},
          "end":              {"type": "string"},
          "stuck_threshold":  {"type": "string", "description": "Default: 50% of window or 100us"},
          "glitch_threshold": {"type": "string", "description": "Default: 5ns"}
        },
        "required": ["file"]
      },
      "result_schema": {
        "anomalies": "array of {type, signal, time, severity, description, ...}",
        "summary": "counts by severity and type"
      },
      "example_cli": "python vcd_analyzer.py anomaly-detect sim.vcd --json"
    }
  ]
}
